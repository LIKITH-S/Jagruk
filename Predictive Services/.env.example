# =============================================================================
# .env.example — Copy to .env and fill in secrets before running locally.
# Never commit .env to version control.
# =============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=predictive-service
APP_VERSION=0.1.0
ENV=development
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_PREFIX=/api/v1

# ── Model artefacts ──────────────────────────────────────────────────────────
MODEL_ARTIFACTS_DIR=/app/artifacts
PRIMARY_MODEL_FILENAME=severity_model.joblib
PREPROCESSOR_FILENAME=preprocessor.joblib
FEATURE_NAMES_FILENAME=feature_names.json

# ── Fusion Engine ─────────────────────────────────────────────────────────────
FUSION_ENGINE_URL=http://fusion-engine:8001
FUSION_ENGINE_API_KEY=changeme
FUSION_ENGINE_TIMEOUT_SECONDS=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
CACHE_TTL_SECONDS=300

# ── Prometheus ────────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090

# ── Drift detection ───────────────────────────────────────────────────────────
DRIFT_WINDOW_SIZE=1000
DRIFT_THRESHOLD=0.05

# ── Paths ─────────────────────────────────────────────────────────────────────
DATA_DIR=/app/data
LOGS_DIR=/app/logs
